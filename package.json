{
  "name": "agent-race-control",
  "productName": "Agent Race Control",
  "version": "0.1.0",
  "description": "Agent Race Control — a session-aware terminal cockpit for Claude Code on native Windows",
  "author": "HelloEnjoy <carlos@helloenjoy.com>",
  "license": "MIT",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./src/renderer/tsconfig.json",
    "test": "vitest run",
    "format": "prettier --write .",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@types/node": "^24.9.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.12",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "marked": "^18.0.6",
    "material-symbols": "^0.45.7",
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
